# CryptoBot — settings file. Credentials are NOT stored here.
# =====================================================================
# ENTER YOUR andX API KEYS IN THE DASHBOARD instead:
#   1. Start the bot (double-click START_EVERYTHING.bat)
#   2. Open http://localhost:5002
#   3. Find the "andX API credentials" panel
#   4. Paste your API key / secret / username (your andX email) /
#      passphrase there, account name "Main" -> Save -> Test connection
# The dashboard saves them to andx_credentials.json on YOUR machine and
# the bot picks them up instantly (no restart needed).
# =====================================================================

# --- andX ---
ANDX_BASE_URL=https://platform.andx.one/api/v1
# Leave these blank — use the dashboard credentials panel (see above).
ANDX_API_KEY=
ANDX_API_SECRET=
ANDX_USERNAME=
ANDX_PASSPHRASE=
ANDX_QUOTE_ASSET=USDT
ANDX_ACCOUNT=Main

# --- Alpaca price data (built-in shared keys; nothing to fill in) ---
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=

# --- routing ---
CRYPTO_EXCHANGE=hybrid
HYBRID_DATA=alpaca
HYBRID_EXEC=andx_browser
# Browser execution: the bot trades through the Chrome window that
# START_EVERYTHING.bat opens (logged into platform.andx.one). This gives
# access to the full ~120-coin universe. Keep that Chrome window OPEN.
ANDX_PW_AUTOSTART=1
ANDX_PW_HEADLESS=0

# CDP-attach: the bot connects to the Chrome that START_EVERYTHING.bat
# launches with --remote-debugging-port=9222. Don't change this.
ANDX_PW_CDP_URL=http://127.0.0.1:9222

# Default risk mode. SNIPER = conviction trading (1-2 big positions, chunky
# TPs, quality over frequency). Use AGGRESSIVE for HFT/volume; REGULAR for
# balanced; CONSERVATIVE for slow A-grade-only.
DEFAULT_RISK_MODE=SNIPER

# Direction: long = LONGS ONLY (recommended — andX is spot-only, it cannot
# actually short). both = longs + shorts; short = shorts only.
DEFAULT_TRADE_MODE=long

# --- safety ---
# 1 = real andX orders (LIVE) + mirror andX state in the live panel
# 0 = portfolio.py routes to sim instead (no andX writes)
# Side-car SIM always runs in parallel (controlled by SIM_PARALLEL below).
LIVE_TRADING=1
SIM_PARALLEL=1
SIM_STARTING_CASH=100000
# andX is spot-only — it cannot short. 0 = no live shorts (correct for andX).
# Leave this 0; DEFAULT_TRADE_MODE=long above also keeps the bot longs-only.
EXEC_SUPPORTS_SHORT=0
