# CryptoBot — env vars (copy to .env or set in PowerShell session)
# -------------------------------------------------------------------

# --- Which exchange to use --------------------------------------------------
# andx  -> uses andx_client.py (your platform — fill in API endpoints)
# ccxt  -> generic CCXT adapter; pair with CCXT_EXCHANGE below for testing
# binance / kraken -> shortcuts for ccxt
CRYPTO_EXCHANGE=andx

# --- andX config (filled by you when wiring up the real API) ---------------
ANDX_BASE_URL=https://api.andx.example/v1
ANDX_API_KEY=
ANDX_API_SECRET=
ANDX_QUOTE_ASSET=USDT

# --- CCXT fallback (for testing while andX is in stub mode) ----------------
# Set CRYPTO_EXCHANGE=ccxt to use these
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_API_SECRET=
CCXT_QUOTE_ASSET=USDT
# Set to 1 to allow real orders via CCXT (default OFF — simulated fills only)
CCXT_LIVE_TRADING=0

# --- Bot tuning ------------------------------------------------------------
STARTING_CASH=100000.00       # sim portfolio starting balance
DAILY_TARGET=1000             # USD/USDT session PnL target
UNIVERSE_SIZE=30              # top-N by 24h volume to scan
UNIVERSE_REFRESH_SEC=300      # how often to refresh the universe
PRICE_CACHE_TTL_SEC=15        # price snapshot cache
PORT=5001                     # dashboard port (5001 so it doesn't collide with SRI MATA on 5000)

# --- Live trading switch ---------------------------------------------------
# 0 = simulated fills against live prices (safe default)
# 1 = real orders via the configured exchange — make sure your API keys have
#     trade permissions and that you've tested in sim mode first
LIVE_TRADING=0
